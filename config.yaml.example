# Example configuration file for the Review Service.
#
# To use, copy this file to 'config.yaml' (or another name) and set the
# CONFIG_FILE environment variable to point to it.
#
# These settings can be overridden by environment variables.
# For example, to override the port, set the SVC_PORT environment variable.
# The prefix is defined in the application (e.g., "SVC_") and keys are uppercase.

# Server port for the service
port: 8080

# PostgreSQL database connection details.
# These are used if 'database_url' is not provided.
db_host: "localhost"
db_port: "5432"
db_user: "postgres"
db_pass: "postgres"
db_name: "product_catalog"

# A full database connection string (DSN).
# If provided, this takes precedence over the individual db_* fields above.
# Example: "postgres://user:password@localhost:5432/product_catalog?sslmode=disable"
database_url: ""

# Redis connection details
redis_host: "localhost"
redis_port: "6379"
